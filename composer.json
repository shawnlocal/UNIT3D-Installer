{
    "name": "unit3d/installer",
    "description": "Modern Installer for UNIT3D v9.2.0",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "ext-dom": "*",
        "ext-curl": "*",
        "symfony/console": "^6.4",
        "symfony/process": "^6.4",
        "symfony/yaml": "^6.4",
        "symfony/var-dumper": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
